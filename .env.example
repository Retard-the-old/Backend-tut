# ── App ──
APP_NAME=Tutorii
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-64-char-random-string
API_V1_PREFIX=/api/v1

# ── Database ──
DATABASE_URL=postgresql+asyncpg://tutorii:tutorii@localhost:5432/tutorii
DATABASE_ECHO=false

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Auth ──
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# ── MamoPay ──
MAMOPAY_API_KEY=sk_test_...
MAMOPAY_BASE_URL=https://sandbox.mamopay.com/manage_api/v1
MAMOPAY_WEBHOOK_SECRET=whsec_...

# ── Anthropic / Claude ──
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ── Subscription ──
SUBSCRIPTION_PRICE_AED=95.00
L1_COMMISSION_RATE=0.40
L2_COMMISSION_RATE=0.05
MINIMUM_PAYOUT_AED=50.00

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AWS SES ──
AWS_SES_REGION=me-south-1
AWS_SES_ACCESS_KEY_ID=AKIA...
AWS_SES_SECRET_ACCESS_KEY=...
FROM_EMAIL=hello@tutorii.com
FROM_NAME=Tutorii

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000"]

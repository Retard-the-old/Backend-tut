# App
APP_NAME=Tutorii
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string

# Database
DATABASE_URL=postgresql+asyncpg://tutorii:tutorii@postgres:5432/tutorii

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# MamoPay (leave empty for now, use sandbox for testing)
MAMOPAY_API_KEY=
MAMOPAY_BASE_URL=https://sandbox.mamopay.com/manage_api/v1
MAMOPAY_WEBHOOK_SECRET=

# AWS SES (leave empty for now)
AWS_SES_REGION=me-south-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
FROM_EMAIL=hello@tutorii.com
FROM_NAME=Tutorii

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
